{
  "name": "steward",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/ensure-playwright.mjs --best-effort && node scripts/ensure-network-tools.mjs && node scripts/ensure-remote-desktop-runtime.mjs --best-effort",
    "network-tools:install": "node scripts/ensure-network-tools.mjs",
    "playwright:install": "node scripts/ensure-playwright.mjs",
    "predev": "node scripts/ensure-network-tools.mjs && node scripts/ensure-playwright.mjs && node scripts/ensure-remote-desktop-runtime.mjs --best-effort && node scripts/free-port.mjs 3010 3011",
    "dev": "next dev --port 3010",
    "prestart": "node scripts/ensure-network-tools.mjs && node scripts/ensure-playwright.mjs && node scripts/ensure-remote-desktop-runtime.mjs --best-effort",
    "build": "next build --webpack",
    "start": "node scripts/start-prod.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "remote-desktop:ensure": "node scripts/ensure-remote-desktop-runtime.mjs",
    "remote-desktop:install": "node scripts/ensure-remote-desktop-runtime.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.54",
    "@ai-sdk/cohere": "^3.0.23",
    "@ai-sdk/google": "^3.0.37",
    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/mistral": "^3.0.22",
    "@ai-sdk/openai": "^3.0.39",
    "@ai-sdk/xai": "^3.0.64",
    "@novnc/novnc": "^1.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "ai": "^6.0.111",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "guacamole-common-js": "^1.5.0",
    "guacamole-lite": "^1.2.0",
    "jose": "^6.1.3",
    "ldapts": "^8.1.7",
    "lucide-react": "^0.576.0",
    "mqtt": "^5.15.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "playwright": "^1.58.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "flatted": "^3.4.0"
  }
}
